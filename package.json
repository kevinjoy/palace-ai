{
  "name": "palace-ai",
  "version": "0.1.0",
  "description": "Personal agentic infrastructure using a court organizational metaphor",
  "type": "module",
  "private": true,
  "bin": {
    "palace": "./src/cli.ts"
  },
  "scripts": {
    "palace": "bun run src/cli.ts",
    "start": "bun run src/cli.ts start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "bun run typecheck"
  },
  "dependencies": {
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@vitest/coverage-v8": "^4.1.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
